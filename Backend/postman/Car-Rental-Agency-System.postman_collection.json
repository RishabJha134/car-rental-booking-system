        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Use this request for both customer and agency login. Save the token from the response."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.data && response.data.token) {",
                  "  pm.environment.set('token', response.data.token);",
                  "  pm.environment.set('user_id', String(response.data.user.id));",
                  "  pm.environment.set('user_role', response.data.user.role);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
